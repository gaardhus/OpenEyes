{
  "name": "OpenEyes",
  "version": "0.2.1",
  "description": "Select any page element and send it to a running OpenCode session.",
  "manifest_version": 2,
  "permissions": [
    "activeTab",
    "tabs",
    "<all_urls>",
    "storage"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon.svg"
    },
    "default_title": "OpenEyes",
    "default_popup": "popup.html"
  },
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "browser_specific_settings": {
    "gecko": {
      "id": "openeyes@your-domain.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
